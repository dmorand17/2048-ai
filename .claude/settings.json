{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cat >> \"$CLAUDE_PROJECT_DIR\"/.claude/hooks-stop.jsonl"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "cat >> \"$CLAUDE_PROJECT_DIR\"/.claude/hooks-skill.jsonl"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(bun run:*)",
      "Bash(git commit:*)",
      "Bash(git add:*)",
      "mcp__gh__*",
      "Read",
      "Write(src/**)",
      "Write(docs/**)",
      "Edit(src/**)",
      "Edit(index.html)"
    ],
    "deny": [],
    "ask": []
  }
}
